---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";
import { siteUrl } from "@/utils/siteUrl";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => data.featured === undefined || !data.featured);
// 首页已展示的总数(featured + recent 的前 N 篇)
const shownOnHome = featuredPosts.length + Math.min(recentPosts.length, SITE.postPerIndex);
const totalCount = sortedPosts.length;
const hiddenCount = Math.max(totalCount - shownOnHome, 0);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-10 pb-8 sm:pt-16 sm:pb-10", "relative"]}>
      <!-- 禅意侧边竖线 -->
      <div class="hero-vline" aria-hidden="true"></div>
      <div class="hero-vline hero-vline--2" aria-hidden="true"></div>

      <div class="flex items-baseline gap-4">
        <h1 class="site-title">
          <span class="site-title__sub">Zero</span>
        </h1>
        <!-- 印章 -->
        <span class="site-seal" aria-hidden="true">無</span>
        <a
          target="_blank"
          href={siteUrl("/rss.xml")}
          class="ml-auto inline-block opacity-60 transition-opacity hover:opacity-100"
          aria-label="rss feed"
          title="RSS Feed"
        >
          <IconRss
            width={20}
            height={20}
            class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
          />
          <span class="sr-only">RSS Feed</span>
        </a>
      </div>

      <p class="mt-6 max-w-xl leading-relaxed text-foreground/80">
        无记，一片留白。
        <br />
        不强求结论，不追赶风口。
        <br />
        把走过的路、看过的书、撞过的墙，慢慢记下。
      </p>
      {
        SOCIALS.length > 0 && (
          <div class="mt-6 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap text-foreground/60 sm:mb-0">链接：</div>
            <Socials />
          </div>
        )
      }
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="section-title">甄选 · Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="section-title">新近 · Recent</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    {
      sortedPosts.length === 0 && (
        <section class="pt-16 pb-24 text-center">
          <p class="text-foreground/60 italic">尚未落笔 · 留白中</p>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href={siteUrl("/posts/")}>
        全部文字
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
      {
        hiddenCount > 0 && (
          <p class="mt-3 text-sm text-foreground/50">
            首页 {shownOnHome} 篇 · 另有 <span class="text-foreground/70">{hiddenCount}</span> 篇在归档
          </p>
        )
      }
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>

<style>
  .hero-vline {
    position: absolute;
    top: 0;
    bottom: 0;
    left: -1.5rem;
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      color-mix(in srgb, var(--accent) 35%, transparent) 20%,
      color-mix(in srgb, var(--accent) 35%, transparent) 80%,
      transparent 100%
    );
    opacity: 0.7;
    pointer-events: none;
  }
  .hero-vline--2 {
    left: auto;
    right: 1.5rem;
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--border) 30%,
      var(--border) 70%,
      transparent 100%
    );
    opacity: 0.5;
  }
  @media (max-width: 640px) {
    .hero-vline--2 { display: none; }
  }

  .site-title {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    line-height: 1;
  }
  .site-title__main {
    font-size: 2.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
  }
  .site-title__sub {
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.3em;
    color: color-mix(in srgb, var(--fg) 70%, transparent);
    text-transform: uppercase;
  }
  @media (min-width: 640px) {
    .site-title__main { font-size: 3.5rem; }
  }

  .site-seal {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    background: var(--accent);
    color: #faf8f3;
    font-family: "STKaiti", "KaiTi", "霞鹜文楷", "LXGW WenKai", serif;
    font-size: 1.25rem;
    font-weight: 700;
    border-radius: 3px;
    transform: translateY(-2px) rotate(-3deg);
    box-shadow: 0 1px 0 color-mix(in srgb, #000 30%, transparent);
    user-select: none;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: var(--fg-deep);
    position: relative;
    padding-left: 0.9rem;
    margin-bottom: 1.5rem;
  }
  .section-title::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.35em;
    bottom: 0.35em;
    width: 3px;
    background: var(--accent);
    border-radius: 1px;
  }
</style>
